{
  "name": "ditto-sdk",
  "version": "1.0.0",
  "description": "Ditto Clipboard Manager Network SDK for TypeScript",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tuanzisama/ditto-typescript-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/tuanzisama/ditto-typescript-sdk/issues"
  },
  "homepage": "https://github.com/tuanzisama/ditto-typescript-sdk#readme",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "release": "bumpp && npm publish",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ditto",
    "clipboard",
    "clipboard-manager",
    "network",
    "sdk",
    "typescript"
  ],
  "author": "tuanzisama",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "typed-struct": "^2.7.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@types/node": "^20.10.0",
    "bumpp": "^11.0.1",
    "eslint": "^10.2.0",
    "tsdown": "^0.21.10",
    "typescript": "^5.3.0"
  }
}